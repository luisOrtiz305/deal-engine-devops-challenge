graph TB
    subgraph Internet
        USER["👤 User / Agency / Airline"]
    end

    subgraph AWS["AWS — us-east-1"]
        subgraph VPC["VPC 10.0.0.0/16"]

            subgraph PublicSubnets["Public Subnets (10.0.1.0/24, 10.0.2.0/24)"]
                ALB["Application Load Balancer\n(HTTPS :443)"]
                NATGW["NAT Gateway"]
            end

            subgraph PrivateSubnets["Private Subnets (10.0.10.0/24, 10.0.11.0/24)"]

                subgraph EKS["EKS Cluster (K8s 1.29)"]

                    subgraph NS_INGRESS["namespace: ingress-nginx"]
                        INGRESS["NGINX Ingress Controller\nTLS termination"]
                    end

                    subgraph NS_PROD["namespace: production"]
                        subgraph FRONTEND["frontend Deployment (2 replicas)"]
                            FE1["Pod: frontend"]
                            FE2["Pod: frontend"]
                        end
                        SVC_FE["Service: frontend\n(ClusterIP)"]

                        subgraph BACKEND["backend Deployment (3-10 replicas via HPA)"]
                            BE1["Pod: backend-api"]
                            BE2["Pod: backend-api"]
                            BE3["Pod: backend-api"]
                        end
                        SVC_BE["Service: backend\n(ClusterIP)"]
                        CM["ConfigMap\n(APP_ENV, LOG_LEVEL...)"]
                        SEC["Secret\n(DB_PASSWORD, API_KEY...)"]
                    end

                    subgraph NS_MON["namespace: monitoring"]
                        PROM["Prometheus"]
                        GRAF["Grafana"]
                    end

                end

                subgraph DB_LAYER["Database Layer"]
                    RDS[("RDS PostgreSQL\n(Multi-AZ)\n10.0.10.50")]
                end
            end

        end

        ECR["ECR\nContainer Registry"]
        CW["CloudWatch\nLogs & Metrics"]
        ACM["ACM\nTLS Certificate"]
        SM["Secrets Manager\n(future)"]
    end

    subgraph CICD["CI/CD — GitHub Actions"]
        GH["GitHub Repository"]
        PIPE["Pipeline:\nbuild → scan → push → deploy"]
    end

    %% Traffic flow
    USER -->|"HTTPS"| ALB
    ALB -->|"forward :443"| INGRESS
    ACM -.->|"TLS cert"| ALB
    INGRESS -->|"/* "| SVC_FE
    INGRESS -->|"/api/*"| SVC_BE
    SVC_FE --> FE1 & FE2
    SVC_BE --> BE1 & BE2 & BE3
    BE1 & BE2 & BE3 -->|"5432"| RDS
    CM & SEC -.->|"env vars"| BE1

    %% CI/CD flow
    GH --> PIPE
    PIPE -->|"docker push"| ECR
    ECR -.->|"image pull"| BE1
    PIPE -->|"kubectl apply"| EKS

    %% Observability
    BE1 & BE2 & BE3 -.->|"logs/metrics"| CW
    PROM -.->|"scrape"| BE1

    %% Outbound
    NATGW -.->|"outbound"| ECR

    style EKS fill:#e8f4f8,stroke:#2196F3
    style NS_PROD fill:#e8f5e9,stroke:#4CAF50
    style NS_MON fill:#fff3e0,stroke:#FF9800
    style NS_INGRESS fill:#f3e5f5,stroke:#9C27B0
    style PublicSubnets fill:#fff9c4,stroke:#FFC107
    style PrivateSubnets fill:#fce4ec,stroke:#E91E63
    style CICD fill:#e0f2f1,stroke:#009688
